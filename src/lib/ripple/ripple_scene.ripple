/**
 * Full Ripple Scene Implementation
 *
 * This component:
 * - Creates Ripple units from JSON data
 * - Provides update() function driven by Svelte's clock (unified timing)
 * - Handles physics, collisions, and rendering
 * - Exports state back to JSON on unmount
 */

import { TrackedArray, effect, untrack } from 'ripple';
import { create_ripple_unit, ripple_unit_to_json, type Ripple_Unit } from '$lib/ripple/ripple_unit.ripple';
import type { Unit_Json } from '$lib/unit_types.js';
import type { Renderer_Colors } from '$lib/renderer.svelte.js';
import { Collisions } from '$lib/collisions.js';
import { colliding } from '$lib/colliding.js';
import { cr, type Collision_Result } from '$lib/collision_result.js';
import { apply_bounce_physics } from '$lib/physics.js';

interface Props {
	width: number;
	height: number;
	units_json: Array<Unit_Json>;
	colors: Renderer_Colors;
	// Getter for reactive Svelte state
	get_simulation_speed: () => number;
	// Callback to register update function (called by Svelte's clock)
	register_update_callback?: (callback: ((dt: number) => void) | null) => void;
	// Callback to register lazy state getter (called by Svelte before unmount)
	on_get_state?: (getter: (() => Array<Unit_Json>) | null) => void;
}

export component RippleScene(props: Props) {
	// Create collision system (framework-agnostic!)
	const collisions = new Collisions();

	// Create Ripple units from JSON
	const units = TrackedArray.from(
		props.units_json,
		(json) => create_ripple_unit(json, props.colors)
	);

	// Create collision bodies ONCE at initialization using untrack()
	// untrack() lets us read tracked properties without making them dependencies
	effect(() => {
		for (const unit of units) {
			// Use untrack to read properties without subscribing
			const type = untrack(() => unit.type);
			const x = untrack(() => unit.x);
			const y = untrack(() => unit.y);

			if (type === 'circle') {
				const radius = untrack(() => unit.radius);
				const scale = untrack(() => unit.scale);
				unit.body = collisions.create_circle(x, y, radius, scale);
			} else if (type === 'polygon') {
				const points = untrack(() => unit.points);
				const rotation = untrack(() => unit.rotation);
				const scale = untrack(() => unit.scale);
				unit.body = collisions.create_polygon(x, y, points, rotation, scale, scale);
			}

			// Store reference back to unit
			if (unit.body) {
				unit.body.unit = unit;
			}
		}

		// Cleanup on unmount
		return () => {
			for (const unit of units) {
				if (unit.body) {
					try {
						unit.body.remove();
					} catch (e) {
						console.warn('[Ripple] Failed to remove collision body:', e);
					}
					unit.body = undefined;
				}
			}
		};
	});

	// Update function called by Svelte's clock
	function update(dt: number): void {
		const sim_speed = props.get_simulation_speed();
		const final_dt = dt * sim_speed;

		// Update collision system
		collisions.update();

		// PHASE 1: Collision detection and response (BEFORE movement, matching Spawn_Demo)
		for (const unit of units) {
			if (!unit.body) continue;

			// Check collisions
			for (const other_body of unit.body.potentials()) {
				if (!other_body.unit) continue;
				const other_unit = other_body.unit as Ripple_Unit;

				if (colliding(unit.body, other_body, cr)) {
					// Handle special behavior collisions
					const has_harmful = unit.behavior_names.includes('Harmful_Behavior');
					const has_player = unit.behavior_names.includes('Player_Controller_Behavior');
					const has_goal = unit.behavior_names.includes('Goal_Behavior');
					const other_has_harmful = other_unit.behavior_names.includes('Harmful_Behavior');
					const other_has_player = other_unit.behavior_names.includes('Player_Controller_Behavior');
					const other_has_goal = other_unit.behavior_names.includes('Goal_Behavior');

					// Player vs Harmful
					if (other_has_harmful && has_player) {
						unit.dead = true;
					} else if (has_harmful && other_has_player) {
						other_unit.dead = true;
					}
					// Player vs Goal
					else if ((other_has_goal && has_player) || (has_goal && other_has_player)) {
						// TODO: Add on_goal callback prop and call scene.exit()
					}
					// Regular collision response - use shared physics algorithm
					else {
						apply_bounce_physics(unit, other_unit, cr);
					}
				}
			}
		}

		// PHASE 2: Movement (AFTER collision response)
		for (const unit of units) {
			if (!unit.body) continue;

			// Movement
			if (!unit.dead) {
				const unit_speed = unit.speed * final_dt;

				if (unit_speed !== 0) {
					if (unit.direction_x !== 0) {
						unit.x += unit.direction_x * unit_speed;
						unit.body.x = unit.x;
					}
					if (unit.direction_y !== 0) {
						unit.y += unit.direction_y * unit_speed;
						unit.body.y = unit.y;
					}
				}
			}

			// Teleporting (even when dead)
			if (unit.teleporting_x !== 0) {
				unit.x += unit.teleporting_x;
				unit.body.x = unit.x;
			}
			if (unit.teleporting_y !== 0) {
				unit.y += unit.teleporting_y;
				unit.body.y = unit.y;
			}
		}
	}

	// Register callbacks
	effect(() => {
		// Register the update function so Svelte's clock can call it
		if (props.register_update_callback) {
			props.register_update_callback(update);
		}

		// Register lazy state getter (Svelte calls this before unmount)
		// This avoids serializing every frame - only when switching renderers
		if (props.on_get_state) {
			const get_state = () => {
				console.log('serializing Ripple state')
				return units.map(u => ripple_unit_to_json(u))
			};
			props.on_get_state(get_state);
		}

		// Cleanup on unmount
		return () => {
			// Unregister callbacks
			if (props.register_update_callback) {
				props.register_update_callback(null);
			}
			if (props.on_get_state) {
				props.on_get_state(null);
			}
		};
	});

	// Render units
	<div>
		<svg
			width={props.width}
			height={props.height}
			style={{
				border: '1px solid #444',
				backgroundColor: props.colors.background ?? 'transparent',
			}}
		>
			for (const unit of units; key unit.id) {
				if (unit.type === 'circle') {
					<circle
						cx={unit.x}
						cy={unit.y}
						r={unit.radius * Math.abs(unit.scale)}
						fill={unit.color}
					/>
				} else if (unit.type === 'polygon' && unit.transformed_points.length >= 3) {
					<polygon
						points={serialize_polygon_points(unit.x, unit.y, unit.transformed_points)}
						fill={unit.color}
					/>
				}
			}
		</svg>
	</div>
}

/**
 * Serialize polygon points to SVG format.
 */
function serialize_polygon_points(x: number, y: number, points: Array<{x: number, y: number}>): string {
	let s = '';
	for (const point of points) {
		s += `${point.x + x},${point.y + y} `;
	}
	return s;
}
