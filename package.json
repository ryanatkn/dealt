{
  "name": "dealt",
  "version": "0.0.0",
  "description": "run node code, for web",
  "license": "AGPL-3.0-only",
  "homepage": "https://dealt.dev",
  "scripts": {
    "start": "echo :D",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanatkn/dealt.git"
  },
  "bugs": {
    "url": "https://github.com/ryanatkn/dealt/issues"
  },
  "keywords": [
    "run",
    "node",
    "code",
    "web"
  ],
  "author": {
    "name": "Ryan Atkinson",
    "email": "ryanatkn@gmail.com",
    "url": "https://ryanatkn.com"
  },
  "engines": {
    "node": ">=12"
  },
  "type": "module",
  "prettier": {
    "useTabs": true,
    "singleQuote": true,
    "trailingComma": "all",
    "bracketSpacing": false,
    "svelteSortOrder": "scripts-markup-styles",
    "overrides": [
      {
        "files": "*.json",
        "options": {
          "useTabs": false
        }
      }
    ]
  },
  "devDependencies": {
    "prettier": "^1.18.2",
    "svelte": "^3.9.1",
    "tslib": "^1.10.0",
    "typescript": "^3.5.3"
